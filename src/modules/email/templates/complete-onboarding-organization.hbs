<html>

<head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f4f4f4;
            margin: 0;
            padding: 0;
        }

        .email-container {
            background-color: #ffffff;
            max-width: 600px;
            margin: 0 auto;
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.08);
        }

        .header {
            background-color: #29323c;
            color: #ffffff;
            text-align: center;
            padding: 24px;
        }

        .content {
            padding: 24px;
            color: #333333;
        }

        .button {
            display: inline-block;
            padding: 12px 28px;
            margin: 24px 0;
            background-color: #2f80ed;
            color: #ffffff !important;
            text-decoration: none;
            border-radius: 9999px;
            font-weight: bold;
        }

        .footer {
            background-color: #f4f4f4;
            color: #777777;
            text-align: center;
            padding: 20px;
            font-size: 12px;
        }
    </style>
</head>

<body>
    <table class='email-container' cellpadding='0' cellspacing='0' width='100%'>
        <tr>
            <td class='header'>
                <h2>Action Required: Complete Onboarding</h2>
            </td>
        </tr>
        <tr>
            <td class='content'>
                <p>Hello,</p>
                <p>An organization <strong>{{organizationName}}</strong> has been created for you.</p>
                <p>Please complete the onboarding process to get started.</p>

                <p style='text-align:center;'>
                    <a href='{{url}}' class='button'>Complete Onboarding</a>
                </p>

                <p style='color: #666666;'>If you did not request this, please ignore this email.</p>
            </td>
        </tr>
        <tr>
            <td class='footer'>
                <p>&copy; {{year}} Runstaff.ai. All rights reserved.</p>
            </td>
        </tr>
    </table>
</body>

</html>