<html>

<head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f4f4f4;
            margin: 0;
            padding: 0;
        }

        .email-container {
            background-color: #ffffff;
            max-width: 600px;
            margin: 0 auto;
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.08);
        }

        .header {
            background-color: #29323c;
            color: #ffffff;
            text-align: center;
            padding: 24px;
        }

        .content {
            padding: 24px;
            color: #333333;
        }

        .inline {
            display: flex;
            align-items: center;
            margin-bottom: 10px;
            flex-wrap: wrap;
        }

        .avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            object-fit: cover;
            margin-right: 10px;
        }

        .button {
            display: inline-block;
            padding: 12px 28px;
            margin: 24px 0;
            background-color: #2f80ed;
            color: #ffffff !important;
            text-decoration: none;
            border-radius: 9999px;
            font-weight: bold;
        }

        .footer {
            background-color: #f4f4f4;
            color: #777777;
            text-align: center;
            padding: 20px;
            font-size: 12px;
        }
    </style>
</head>

<body>
    <table class='email-container' cellpadding='0' cellspacing='0' width='100%'>
        <tr>
            <td class='header'>
                <h2>You've Been Invited!</h2>
            </td>
        </tr>
        <tr>
            <td class='content'>
                <div class='inline'>
                    <p><strong>{{inviterName}}</strong> invited you to join the project <strong>{{projectName}}</strong>
                        at
                        <strong>{{teamName}}</strong>.
                    </p>
                </div>

                <p style='text-align:center;'>
                    <a href='{{url}}' class='button'>Join Project</a>
                </p>

                <p style='color: #666666;'>You can access all your projects anytime by logging into your Staffwatch
                    account.</p>
            </td>
        </tr>
        <tr>
            <td class='footer'>
                <p>&copy; {{year}} Runstaff.ai. All rights reserved.</p>
            </td>
        </tr>
    </table>
</body>

</html>