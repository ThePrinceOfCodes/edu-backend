# Port number
PORT=8000

ENV="local"

NODE_ENV="development"

DB_SSL=true
MONGODB_URL="mongodb://localhost:27017/edt-dev"
SHAREDB_MONGODB_URL="mongodb://localhost:27017/sharedb-edt-dev"
SCHEDULER_COLLECTION="tasks-manager"

# JWT
JWT_SECRET="your-jwt-secret"
ENCRYPTION_KEY="your-encryption-key"
JWT_ACCESS_EXPIRATION_MINUTES=300
JWT_REFRESH_EXPIRATION_DAYS=30
JWT_RESET_PASSWORD_EXPIRATION_MINUTES=20
JWT_VERIFY_EMAIL_EXPIRATION_MINUTES=30

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME="your-smtp-username"
SMTP_PASSWORD="your-smtp-password"
EMAIL_FROM="no-reply@example.com"

CLIENT_URL="http://localhost:5400"

# Internal admin seed
SEED_INTERNAL_ADMIN_ON_STARTUP=false
INTERNAL_ADMIN_NAME="Internal Admin"
INTERNAL_ADMIN_EMAIL="admin@example.com"
INTERNAL_ADMIN_PASSWORD="ChangeMe1234"
INTERNAL_ADMIN_ROLE="super-admin"

REDIS_PASSWORD=""
REDIS_HOST=localhost
REDIS_PORT="6379"
REDIS_BASE_KEY="EDT:V1:DEV:LOCAL:"

GOOGLE_CLOUD_PROJECT_ID="your-google-project-id"
GOOGLE_CLOUD_LOCATION="us"
GOOGLE_CLOUD_DOCUMENT_AI_PROCESSOR_ID="your-processor-id"
DOCUMENT_AI_PROCESSOR_ID="your-processor-id"

# Google Service Account credentials (replaces GOOGLE_APPLICATION_CREDENTIALS file)
GCP_SA_TYPE="service_account"
GCP_SA_PROJECT_ID="your-gcp-project-id"
GCP_SA_PRIVATE_KEY_ID="your-private-key-id"
GCP_SA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GCP_SA_CLIENT_EMAIL="your-service-account@your-project.iam.gserviceaccount.com"
GCP_SA_CLIENT_ID="your-client-id"
GCP_SA_TOKEN_URI="https://oauth2.googleapis.com/token"
GCP_SA_AUTH_PROVIDER_CERT_URL="https://www.googleapis.com/oauth2/v1/certs"
GCP_SA_CLIENT_CERT_URL="https://www.googleapis.com/robot/v1/metadata/x509/your-service-account%40your-project.iam.gserviceaccount.com"
GCP_SA_UNIVERSE_DOMAIN="googleapis.com"

PUSH_NOTIFICATIONS_ENABLED=true

ATTENDANT_UPLOAD_DIR="attendance_extraction_images"
ATTENDANT_EXTRACTION_USE_PI=true
ATTENDANT_EXTRACTION_PROVIDER="google"
ATTENDANT_EXTRACTION_MODEL="gemini-2.5-pro"
ATTENDANT_EXTRACTION_MAX_UPLOAD_MB=10

OPENAI_API_KEY=""
GEMINI_API_KEY=""
ANTHROPIC_API_KEY=""

# Pi OAuth Credentials
PI_OAUTH_PROVIDER=""
PI_OAUTH_PROVIDER=open-codex
PI_OAUTH_CLIENT_ID=app_EMoamEEZ73f0CkXaXp7hrann
PI_OAUTH_TOKEN_URL=https://auth.openai.com/oauth/token
PI_OAUTH_ACCESS_TOKEN=""
PI_OAUTH_REFRESH_TOKEN=""
PI_OAUTH_EXPIRES_AT=""
